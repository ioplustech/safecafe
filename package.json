{
  "name": "safecafe",
  "version": "0.2.0",
  "private": true,
  "description": "Guided Safenet staking web app and CLI with a calm consumer-grade experience.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "safecafe": "./cli/dist/index.js"
  },
  "scripts": {
    "dev": "pnpm build:packages && vite --host 0.0.0.0",
    "build": "pnpm build:web && pnpm build:cli",
    "build:packages": "pnpm build:safe-lite && pnpm build:rate-limit",
    "build:rate-limit": "pnpm --filter @safecafe/rate-limit build",
    "build:safe-lite": "pnpm --filter @safecafe/safe-lite build",
    "build:web": "pnpm build:packages && tsc -b && vite build",
    "build:cli": "pnpm build:packages && cd cli && tsup --config tsup.config.ts",
    "build:cli:bun": "pnpm build:cli && bun build cli/dist/index.js --compile --outfile cli/dist-bin/safecafe",
    "preview": "vite preview --host 0.0.0.0",
    "cloudflare:preview": "pnpm build:web && wrangler pages dev dist",
    "cloudflare:deploy": "pnpm build:web && wrangler pages deploy dist --project-name safecafe",
    "ipfs:publish": "node scripts/publish-ipfs.mjs",
    "ipfs:publish:dist": "node scripts/publish-ipfs.mjs --skip-build",
    "ipfs:size": "node scripts/publish-ipfs.mjs --skip-build --size-check",
    "ipfs:sync-records": "node scripts/publish-ipfs.mjs --sync-records",
    "release": "tsx scripts/release.ts",
    "cli": "node scripts/run-cli.mjs",
    "cli:packed": "node scripts/run-cli.mjs --command node --entry cli/dist/index.js",
    "cli:bun": "node scripts/run-cli.mjs --command bun --entry cli/index.ts",
    "check": "pnpm check:locales && pnpm build:packages && pnpm test:rate-limit && tsc -b --noEmit && pnpm check:release && biome check .",
    "check:locales": "node scripts/check-locales.mjs",
    "check:release": "tsc -p scripts/release/tsconfig.json",
    "format": "biome check --write .",
    "test:agent": "pnpm test:agent:core && pnpm test:agent:stream-ui",
    "test:agent:core": "tsx scripts/agent-core-test.mjs",
    "test:agent:stream-ui": "VITE_AGENT_LAUNCHER_DRAGGABLE=true VITE_RPC_URL=/api/rpc/ethereum node scripts/agent-stream-ui-test.mjs",
    "test:safe-lite": "tsx scripts/safe-lite-test.mjs",
    "test:e2e": "VITE_AGENT_LAUNCHER_DRAGGABLE=true VITE_RPC_URL=/api/rpc/ethereum pnpm build:web && node scripts/e2e-test.mjs",
    "test:e2e:live-mock": "VITE_AGENT_LAUNCHER_DRAGGABLE=true VITE_RPC_URL=/api/rpc/ethereum pnpm build:web && node scripts/e2e-live-mock-test.mjs --server=wrangler",
    "test:e2e:live-mock:dev": "VITE_AGENT_LAUNCHER_DRAGGABLE=true VITE_RPC_URL=/api/rpc/ethereum node scripts/e2e-live-mock-test.mjs --server=dev",
    "test:e2e:ui-sweep": "VITE_RPC_URL=/api/rpc/ethereum pnpm build:web && node scripts/e2e-ui-sweep.mjs",
    "canary:web": "pnpm test:e2e:live-mock",
    "canary:web:dev": "pnpm test:e2e:live-mock:dev",
    "test:mock-chain": "node scripts/e2e/mockChain-test.mjs",
    "test:rate-limit": "pnpm test:rate-limit:core && pnpm build:rate-limit && pnpm test:rate-limit:server",
    "test:rate-limit:core": "pnpm --filter @safecafe/rate-limit test",
    "test:rate-limit:server": "tsx --test src/server/ipRateLimit.test.ts",
    "test:release": "pnpm check:release && tsx scripts/release/core-test.ts && tsx scripts/release-test.ts",
    "test:cli:safe": "tsx scripts/cli-safe-flow-test.mjs",
    "test:integration": "pnpm build:cli && node scripts/integration-test.mjs",
    "test:system": "pnpm build && node scripts/system-test.mjs"
  },
  "dependencies": {
    "@safecafe/rate-limit": "workspace:*",
    "@safecafe/safe-lite": "workspace:*",
    "@vitejs/plugin-react": "6.0.3",
    "commander": "14.0.2",
    "lucide-react": "0.563.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "viem": "2.55.0",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@filebase/sdk": "1.0.6",
    "@playwright/test": "^1.61.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "tsup": "8.5.1",
    "wrangler": "4.110.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "packageManager": "pnpm@11.0.0-rc.0"
}
