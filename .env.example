# -----------------------------------------------------------------------------
# Web app, browser-exposed variables
# Only VITE_* variables are exposed to the browser bundle.
# -----------------------------------------------------------------------------
VITE_RPC_URL=
VITE_AGENT_AUTH=true
VITE_AGENT_LAUNCHER_DRAGGABLE=false
VITE_TOAST_DURATION_MS=3600

# -----------------------------------------------------------------------------
# Cloudflare Pages Functions / server-side runtime
# Keep these server-side. Do not expose secrets through VITE_* variables.
# -----------------------------------------------------------------------------
SAFECAFE_RPC_URL=
SAFECAFE_RPC_URLS=
SAFECAFE_AUTH_SECRET=
SAFECAFE_RPC_ALLOW_ALL_WALLETS=false
SAFECAFE_API_IP_RATE_LIMIT_PER_MINUTE=120
SAFECAFE_AGENT_IP_RATE_LIMIT_PER_MINUTE=20
SAFECAFE_AGENT_FEEDBACK_IP_RATE_LIMIT_PER_MINUTE=20
SAFECAFE_AUTH_IP_RATE_LIMIT_PER_MINUTE=30
SAFECAFE_READ_API_IP_RATE_LIMIT_PER_MINUTE=60
SAFECAFE_RPC_IP_RATE_LIMIT_PER_MINUTE=120
SAFECAFE_SAFE_TX_IP_RATE_LIMIT_PER_MINUTE=30

# -----------------------------------------------------------------------------
# Safe Transaction Service, server-side and CLI only
# -----------------------------------------------------------------------------
SAFECAFE_SAFE_API_KEYS=
SAFECAFE_SAFE_TX_SERVICE_URL=

# -----------------------------------------------------------------------------
# Staking Agent LLM upstream, server-side only
# -----------------------------------------------------------------------------
SAFECAFE_LLM_API_BASE=
SAFECAFE_LLM_API_MODEL=
SAFECAFE_LLM_API_KEY=
SAFECAFE_LLM_TIMEOUT_MS=30000
SAFECAFE_LLM_MAX_TOKENS=512
SAFECAFE_LLM_HEADER=
SAFECAFE_AGENT_DAILY_LIMIT=100
SAFECAFE_AGENT_FEEDBACK_DAILY_LIMIT=20

# -----------------------------------------------------------------------------
# CLI, local automation only
# Never commit real private keys. Prefer key files or CI secrets.
# -----------------------------------------------------------------------------
SAFECAFE_CLI_PRIVATE_KEY=
SAFECAFE_CLI_PRIVATE_KEY_FILE=
SAFECAFE_CLI_PRIVATE_KEYS=
SAFECAFE_CLI_PRIVATE_KEY_FILES=
SAFECAFE_CLI_SIGNER_ADDRESS=
SAFECAFE_CLI_SESSION_DIR=

# -----------------------------------------------------------------------------
# Filebase / IPFS release publishing
# -----------------------------------------------------------------------------
FILEBASE_ACCESS_TOKEN=
FILEBASE_SECRET_KEY=
FILEBASE_BUCKET=safecafe
FILEBASE_RELEASE_KEY_PREFIX=releases
FILEBASE_IPFS_MAX_BYTES=1500000
FILEBASE_UPLOAD_CONCURRENCY=6

# -----------------------------------------------------------------------------
# Local testing / mock-only switches
# Never enable these in production.
# -----------------------------------------------------------------------------
SAFECAFE_MOCK_ACCOUNT_LIVE=false
SAFECAFE_MOCK_ACCOUNT=
SAFECAFE_AGENT_TEST_VERIFIED_ACCESS=false
VITE_MOCK_REWARD_PROOF=false
